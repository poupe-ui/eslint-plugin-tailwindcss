{
  "name": "@poupe/eslint-plugin-tailwindcss",
  "version": "0.2.6",
  "type": "module",
  "description": "ESLint plugin for Tailwind CSS v4 with advanced linting rules",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://github.com/poupe-ui/eslint-plugin-tailwindcss#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poupe-ui/eslint-plugin-tailwindcss.git"
  },
  "bugs": {
    "url": "https://github.com/poupe-ui/eslint-plugin-tailwindcss/issues"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "tailwind",
    "tailwindcss",
    "tailwind-css",
    "css",
    "linting"
  ],
  "sideEffects": false,
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    },
    "./configs/*": {
      "import": "./dist/configs/*.mjs"
    },
    "./parser": {
      "import": "./dist/parser.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "clean": "rimraf dist node_modules",
    "dev:prepare": "unbuild --stub",
    "lint": "cross-env DEBUG=eslint:eslint eslint --fix .",
    "postinstall": "[ -s dist/index.mjs ] || unbuild --stub",
    "precommit": "run-s lint type-check test build",
    "prepack": "run-s lint type-check test build publint",
    "publint": "publint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint/core": "~0.17.0",
    "@eslint/css": "~0.14.1",
    "@eslint/css-tree": "^3.6.1"
  },
  "devDependencies": {
    "@poupe/eslint-config": "~0.8.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.10.6",
    "@vitest/coverage-v8": "~4.0.18",
    "cross-env": "~10.1.0",
    "eslint": "^9.39.3",
    "eslint-plugin-perfectionist": "^4.15.1",
    "npm-run-all2": "^8.0.4",
    "pkg-pr-new": "~0.0.65",
    "publint": "^0.3.18",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "unbuild": "~3.6.1",
    "vitest": "~4.0.18"
  },
  "peerDependencies": {
    "@eslint/css": "~0.14.1",
    "eslint": "^9.30.0"
  },
  "engines": {
    "node": ">= 20.19.0",
    "pnpm": ">= 10.30.3"
  },
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268",
  "publishConfig": {
    "access": "public"
  }
}
